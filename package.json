{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend/*"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f",
    "docker:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml up -d",
    "test:e2e": "cd packages/e2e && npx playwright test",
    "test:e2e:ui": "cd packages/e2e && npx playwright test --ui"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "bun-types": "latest",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1"
  }
}