generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum RoundStatus {
  BETTING
  RUNNING
  CRASHED
}

enum BetStatus {
  PENDING
  CASHED_OUT
  LOST
}

model Round {
  id         String      @id @default(uuid())
  status     RoundStatus
  crashPoint Float       @map("crash_point")
  serverSeed String      @map("server_seed")
  publicSeed String      @map("public_seed")
  hash       String
  nonce      Int         @default(0)
  createdAt  DateTime    @default(now()) @map("created_at")
  bets       Bet[]

  @@index([status])
  @@map("rounds")
}

model Bet {
  id                  String    @id @default(uuid())
  roundId             String    @map("round_id")
  playerId            String    @map("player_id")
  amountCents         BigInt    @map("amount_cents")
  multiplierAtCashout Float?    @map("multiplier_at_cashout")
  autoCashoutAt       Float?    @map("auto_cashout_at")
  status              BetStatus
  payoutCents         BigInt?   @map("payout_cents")
  createdAt           DateTime  @default(now()) @map("created_at")
  round               Round     @relation(fields: [roundId], references: [id])

  @@unique([roundId, playerId])
  @@index([playerId, createdAt])
  @@index([roundId])
  @@map("bets")
}

model OutboxEvent {
  id          String    @id @default(uuid())
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  routingKey  String    @map("routing_key")
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  @@index([publishedAt])
  @@map("outbox_events")
}
